{
  "name": "pilot",
  "version": "0.4.12",
  "description": "Pilot — management plane for pi.dev coding agent. Pack manager, session manager, profile manager, stats, and doctor.",
  "type": "module",
  "main": "./dist/cli.js",
  "bin": {
    "pilot": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:offline": "PILOT_SKIP_NETWORK=1 vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test --max-warnings 0",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "release": "np"
  },
  "keywords": [
    "pi",
    "pi-coding-agent",
    "ai-agent",
    "cli",
    "management",
    "pilot"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@fastify/cookie": "^11.0.2",
    "commander": "^12.1.0",
    "fastify": "^5.9.0",
    "kleur": "^4.1.5",
    "ora": "^8.0.1",
    "smol-toml": "^1.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "np": "^10.0.0",
    "prettier": "^3.3.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wwppee/pilot.git"
  },
  "bugs": {
    "url": "https://github.com/wwppee/pilot/issues"
  },
  "homepage": "https://github.com/wwppee/pilot#readme"
}
